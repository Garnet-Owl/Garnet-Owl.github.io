generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          String    @id @default(uuid())
  title       String
  description String
  technologies String[] 
  githubUrl   String?
  liveUrl     String?
  imageUrl    String?
  completedAt DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
}